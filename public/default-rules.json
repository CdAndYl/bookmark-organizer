        }
      ]
    },
    {
      "id": "ai-tempmail",
      "categoryId": "ai",
      "subfolderId": "ai-tempmail",
      "weight": 6,
      "matchers": [
        {
          "field": "all",
          "type": "keyword",
          "pattern": "临时邮箱,temp mail,duckmail,gptmail,cloud mail,gmail1888,215.im"
