        { "field": "path", "type": "regex", "pattern": "/ai(/|$)|无限ai|开卡|ai编码知识" }
      ]
    },
    {
      "id": "ai-tools",
      "categoryId": "ai",
      "subfolderId": "ai-tools",
      "weight": 5,
      "matchers": [
        {
          "field": "all",
          "type": "keyword",
          "pattern": "chatgpt,openai,claude,coze,gemini,gpt,llm,大模型,prompt,midjourney,stable,cherry-ai,anyrouter,agent,mcp"
        }
      ]
    },
    {
      "id": "ai-coding",
      "categoryId": "ai",
      "subfolderId": "ai-coding",
      "weight": 6,
      "matchers": [
        {
          "field": "all",
          "type": "keyword",
          "pattern": "claude code,codex,agent skills,mcp,workflow,开发调优"
